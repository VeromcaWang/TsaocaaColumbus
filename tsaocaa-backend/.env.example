# Local development (H2 in-memory database is used by default)
# These are only needed when running with the 'lambda' profile locally

DB_URL=jdbc:mysql://localhost:3306/tsaocaa
DB_USER=tsaocaa_user
DB_PASSWORD=your-db-password

COGNITO_ISSUER_URI=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_XXXXXXXXX

S3_BUCKET_NAME=tsaocaa-columbus-assets
SNS_TOPIC_ARN=arn:aws:sns:us-east-2:123456789012:tsaocaa-columbus-notifications

AWS_REGION=us-east-2
